# Required: PostgreSQL connection string. Use sslmode=require in production.
DATABASE_URL=

# Optional: OpenAI for AI-assisted module creation, prompts, embeddings
OPENAI_API_KEY=

# Optional: Vercel Blob for file uploads (dashboard + entity attachments)
BLOB_READ_WRITE_TOKEN=

# Optional: Platform billing (displayed on Subscription page). Defaults: $0 platform, $25/user/month.
# BILLING_PLATFORM_FEE_USD=
# BILLING_PER_USER_FEE_USD=

# Optional: Stripe (platform billing + Connect). Leave empty to skip Stripe features.
# Create a per-seat Price in Stripe at $25/month and set STRIPE_PLATFORM_PRICE_ID to match BILLING_PER_USER_FEE_USD.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_PLATFORM_PRICE_ID=
# Optional: Free trial (days) for new subscriptions. e.g. 14 = 2-week trial. Leave empty for no trial.
STRIPE_TRIAL_DAYS=14

# Optional: Resend for transactional email (approvals, payment failed, webhook failed)
RESEND_API_KEY=
EMAIL_FROM=

# Optional: Public URL for redirects (Stripe return, checkout). Defaults to VERCEL_URL or http://localhost:3000
NEXT_PUBLIC_APP_URL=

# Optional: Subscription grace period (days) when payment is past_due. Default 7.
SUBSCRIPTION_GRACE_DAYS=

# Optional: API rate limit per tenant per minute. Default 100.
API_RATE_LIMIT_PER_MINUTE=

# Optional: CORS origin for /api/v1 (tenant API). Default * (any origin). Set to a specific origin (e.g. https://app.example.com) in production to restrict.
CORS_ORIGIN=

# Optional: Secret for cron endpoints (e.g. webhook retries). Set and use in Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# Required for tenant end-user auth (customer logins). Must be at least 32 characters. Used to sign JWTs for POST .../auth/login and .../auth/register.
JWT_SECRET=

# Optional: Set to 1 or true to log each /api/v1 request (method + path + request ID) to the server console. For debugging.
DEBUG_API_LOGGING=

# Optional: Set to 1 or true to return 503 "Under maintenance" for all routes except GET /api/health. Use for deployments or brief outages.
MAINTENANCE_MODE=

# Optional: Override version shown in GET /api/health. Defaults to package.json version; Vercel sets VERCEL_GIT_COMMIT_SHA as buildId.
APP_VERSION=

# Optional: 32-byte hex key (64 chars) for encrypting integration credentials (e.g. QBO OAuth tokens). Generate with: openssl rand -hex 32
INTEGRATION_ENCRYPTION_KEY=

# Optional: Comma-separated list of emails that can enable "Developer setup" per tenant (API keys, webhooks, Integrations). When set, only these users see the "Turn on developer setup" control in Settings.
PLATFORM_ADMIN_EMAILS=

# Secrets rotation: see docs/OPERATIONS.md for rotating CRON_SECRET and INTEGRATION_ENCRYPTION_KEY.
